# ============================================================
# Cerebrum .gitignore
# ============================================================

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec
MANIFEST

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
secrets/
credentials/

# ── Testing ───────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
junit*.xml
benchmark-results.json

# ── Type Checking ─────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── IDEs ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
apps/web/.next/
apps/web/out/
apps/web/.turbo/
*.tsbuildinfo
apps/web/coverage/

# ── ML / Data ─────────────────────────────────────────────────
*.pkl
*.joblib
*.h5
*.hdf5
*.pt
*.pth
*.onnx
*.parquet
mlruns/
mlartifacts/
models/ml/saved/

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Documentation ─────────────────────────────────────────────
site/

# ── Temporary ─────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig

# ── Datasets (keep examples, ignore large files) ──────────────
datasets/raw/
datasets/processed/
!datasets/examples/
