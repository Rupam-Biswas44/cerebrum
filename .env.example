# ============================================================
# Cerebrum — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ============================================================
# Application
# ============================================================
APP_NAME=Cerebrum
APP_ENV=development            # development | staging | production
APP_VERSION=0.1.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_64_CHARS_MINIMUM

# ============================================================
# Database — PostgreSQL
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cerebrum
POSTGRES_USER=cerebrum
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DATABASE_URL=postgresql+asyncpg://cerebrum:CHANGE_ME_SECURE_PASSWORD@localhost:5432/cerebrum
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================
# Cache — Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
REDIS_CACHE_TTL=3600

# ============================================================
# Object Storage — MinIO
# ============================================================
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_DATASETS=cerebrum-datasets
MINIO_BUCKET_MODELS=cerebrum-models
MINIO_BUCKET_REPORTS=cerebrum-reports
MINIO_SECURE=false

# ============================================================
# Vector Database — Qdrant
# ============================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=CHANGE_ME_QDRANT_API_KEY
QDRANT_COLLECTION_MEMORY=cerebrum_memory
QDRANT_COLLECTION_DOCUMENTS=cerebrum_documents

# ============================================================
# Graph Database — Neo4j
# ============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# ============================================================
# LLM Providers
# ============================================================
# OpenAI
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# Anthropic (optional)
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Ollama — local models (no API key needed)
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Default LLM provider: openai | anthropic | ollama
LLM_PROVIDER=openai
LLM_FALLBACK_PROVIDER=ollama

# ============================================================
# Embeddings
# ============================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu       # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=64

# ============================================================
# JWT Authentication
# ============================================================
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# OAuth2 (optional)
# ============================================================
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# ============================================================
# Celery — Task Queue
# ============================================================
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false        # Set true to run tasks synchronously in tests

# ============================================================
# MLflow — Experiment Tracking
# ============================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cerebrum
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
MLFLOW_ARTIFACT_ROOT=s3://cerebrum-models/mlflow

# ============================================================
# Observability
# ============================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=cerebrum-api
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json | text

# ============================================================
# Frontend
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=Cerebrum
NEXT_PUBLIC_APP_VERSION=0.1.0

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ============================================================
# Security
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
MAX_FILE_UPLOAD_SIZE_MB=500
ALLOWED_FILE_TYPES=csv,xlsx,json,parquet,pdf,txt

# ============================================================
# Agent Configuration
# ============================================================
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=300
AGENT_MEMORY_WINDOW=20            # number of past messages to include
PLANNER_MAX_SUBTASKS=15
CRITIC_HALLUCINATION_THRESHOLD=0.7

# ============================================================
# Email (for notifications)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@cerebrum.ai
